# Copy to .env and fill in. Only VITE_-prefixed vars reach the browser.

# Optional: Luma AI key (server-side only — NOT exposed to the client bundle).
LUMA_API_KEY=

# --- WebAR (AR.js marker-based 6DoF) ---
VITE_ARJS_URL=https://cdn.jsdelivr.net/gh/AR-js-org/AR.js@3.4.5/three.js/build/ar-threex.js
VITE_AR_MARKER=hiro
VITE_AR_MARKER_SIZE=0.15
VITE_AR_POSE_SCALE=8

# --- LLM choreographer (Claude, server-side) ---
ANTHROPIC_API_KEY=

# --- Generate Movie (Luma AI) ---
VITE_LUMA_MODEL=ray-2
VITE_LUMA_DURATION=5s
VITE_LUMA_RESOLUTION=720p
VITE_LUMA_ASPECT=16:9

# --- AWS (server-side only) ---
AWS_REGION=us-east-1
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
S3_BUCKET=
S3_PUBLIC_BASE_URL=
AURORA_RESOURCE_ARN=
AURORA_SECRET_ARN=
AURORA_DATABASE=
